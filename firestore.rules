rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isLoggedIn() {
      return request.auth != null;
    }
    function isLogistics() {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == "active");
    }
    function isManager() {
      return isLogistics() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "logistics_manager" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "manager" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }
    function isAdmin() {
      return isLogistics() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "logistics_manager" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }
    match /items/{itemId} {
      allow read: if isLoggedIn();
      // Staff can adjust stock levels (sizeMap qty) but should not be able
      // to create/delete or edit item metadata. Managers/admins can.
      allow create: if isManager();
      allow delete: if isManager();
      allow update: if isManager()
                    || (isLogistics()
                        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["sizeMap", "updatedAt"]));
    }
    match /personnel/{personnelId} {
      allow read: if isLogistics() || request.auth.uid == resource.data.authUid;
      allow create: if isLogistics();
      allow update: if isLogistics();
      allow delete: if isManager();
    }
    match /transactions/{txId} {
      allow read: if isLogistics() || request.auth.uid == resource.data.personnelAuthUid;
      allow create: if isLogistics();
      allow update: if false;
      allow delete: if false;
    }
    match /requests/{reqId} {
      allow read: if isLogistics() || request.auth.uid == resource.data.personnelAuthUid;
      allow create: if isLoggedIn();
      allow update: if isLogistics();
      allow delete: if false;
    }
    match /backordered/{boId} {
      allow read, write: if isLogistics();
    }
    match /audit_log/{eventId} {
      allow read: if isLogistics();
      allow create: if isLogistics()
                    && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }
    match /order_lists/{listId} {
      allow read, write: if isLogistics();
    }
    match /onboarding_drafts/{draftId} {
      allow read, write: if isLogistics();
    }
    match /app_config/{docId} {
      // Template (and any future app-wide config) is read by every
      // logistics user so `loadTemplate` can consult it on onboarding
      // session start. Only admins can edit — the Settings UI enforces
      // this client-side, and this rule guarantees it server-side.
      allow read: if isLogistics();
      // Managers can edit catalog categories (shared taxonomy). Other config
      // docs remain admin-only.
      allow write: if (docId == "catalog_categories" && isManager())
                   || isAdmin();
    }
    match /users/{userId} {
      allow read: if isLogistics();
      allow write: if isAdmin();
    }
  }
}
